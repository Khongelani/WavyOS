# ─────────────────────────────────────────────────────────────────────────────
# WavyOS — Environment Configuration
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (single owner login) ─────────────────────────────────────────────────
OWNER_EMAIL=founder@example.com
OWNER_PASSWORD=changeme123
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_random_secret_at_least_32_chars

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wavy:wavy@db:5432/wavyos

# ── OpenAI (optional — app runs in demo mode without this) ────────────────────
# Leave blank to use demo output for all AI features
OPENAI_API_KEY=
# Preferred model — gpt-4o gives best signal quality; gpt-3.5-turbo is faster/cheaper
OPENAI_MODEL=gpt-4o

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Web Intelligence ──────────────────────────────────────────────────────────
# Google Search via Serper — free tier: 2,500 queries/month. Get key at serper.dev
SERPER_API_KEY=
# Set to false to disable all external scanning
ENABLE_WEB_INTELLIGENCE=true
# Minimum hours between scans per company (cooldown)
SCAN_COOLDOWN_HOURS=1
# Max news articles stored per scan
MAX_NEWS_RESULTS=20
# Enable/disable individual scan steps
WEBSITE_SCRAPE_ENABLED=true
JSE_DATA_ENABLED=true
